//@version=5
indicator("FTMO Risk Manager v2", overlay=false)

// ═══════════════════════════════════════════════════════════
//  FTMO RISK MANAGER v2 — всі параметри вводяться вручну
// ═══════════════════════════════════════════════════════════

// ─── ГРУПА 1: БАЛАНС РАХУНКУ ─────────────────────────────────
var float i_balance = input.float(
     defval   = 100.0,
     title    = "💰 Початковий баланс ($)",
     minval   = 1.0,
     step     = 10.0,
     group    = "💰 Баланс рахунку",
     tooltip  = "Твій реальний баланс без плеча. Наприклад: $100")

// ─── ГРУПА 2: ПРАВИЛА FTMO ────────────────────────────────────
var float i_dailyLossPct = input.float(
     defval   = 5.0,
     title    = "Max Daily Loss (%)",
     minval   = 0.1,
     maxval   = 20.0,
     step     = 0.5,
     group    = "📏 Правила FTMO",
     tooltip  = "FTMO стандарт: 5%. Максимальний збиток за один день")

var float i_maxLossPct = input.float(
     defval   = 10.0,
     title    = "Max Total Loss (%)",
     minval   = 0.1,
     maxval   = 50.0,
     step     = 0.5,
     group    = "📏 Правила FTMO",
     tooltip  = "FTMO стандарт: 10%. Максимальний загальний збиток")

var float i_profitTargetPct = input.float(
     defval   = 10.0,
     title    = "Profit Target (%)",
     minval   = 0.1,
     maxval   = 100.0,
     step     = 0.5,
     group    = "📏 Правила FTMO",
     tooltip  = "FTMO стандарт: 10%. Ціль прибутку для проходження челенджу")

var float i_riskPerTradePct = input.float(
     defval   = 1.0,
     title    = "Ризик на 1 угоду (%)",
     minval   = 0.1,
     maxval   = 5.0,
     step     = 0.1,
     group    = "📏 Правила FTMO",
     tooltip  = "Рекомендовано не більше 1-2% на угоду")

var int i_maxDailyTrades = input.int(
     defval   = 5,
     title    = "Макс. угод на день",
     minval   = 1,
     maxval   = 50,
     step     = 1,
     group    = "📏 Правила FTMO",
     tooltip  = "Ліміт кількості угод на день для контролю оверtrading")

// ─── ГРУПА 3: ПОТОЧНИЙ P&L (вводиш вручну) ───────────────────
var float i_totalPnL = input.float(
     defval   = 0.0,
     title    = "Загальний P&L ($)",
     minval   = -100000.0,
     maxval   = 100000.0,
     step     = 0.01,
     group    = "📊 Поточний стан рахунку",
     tooltip  = "Вводь вручну свій поточний загальний прибуток/збиток у доларах. Збиток = від'ємне число")

var float i_dailyPnL = input.float(
     defval   = 0.0,
     title    = "Денний P&L ($)",
     minval   = -100000.0,
     maxval   = 100000.0,
     step     = 0.01,
     group    = "📊 Поточний стан рахунку",
     tooltip  = "Вводь вручну свій поточний денний прибуток/збиток. Скидай на 0 щодня")

var int i_dailyTradesCount = input.int(
     defval   = 0,
     title    = "Угод сьогодні (кількість)",
     minval   = 0,
     maxval   = 200,
     step     = 1,
     group    = "📊 Поточний стан рахунку",
     tooltip  = "Вводь вручну кількість угод які вже відкрив сьогодні")

// ─── ГРУПА 4: ВІДОБРАЖЕННЯ ────────────────────────────────────
var bool i_showChart = input.bool(
     defval   = true,
     title    = "Показувати лінії лімітів на графіку",
     group    = "🎨 Відображення")

var bool i_showWarnings = input.bool(
     defval   = true,
     title    = "Попередження при 75% від ліміту",
     group    = "🎨 Відображення")

// ─── РОЗРАХУНОК ЛІМІТІВ ──────────────────────────────────────
float dailyLossLimit  = i_balance * (i_dailyLossPct  / 100)
float maxLossLimit    = i_balance * (i_maxLossPct    / 100)
float profitTarget    = i_balance * (i_profitTargetPct / 100)
float riskPerTrade    = i_balance * (i_riskPerTradePct / 100)

float currentEquity   = i_balance + i_totalPnL

// ─── СТАТУСИ ─────────────────────────────────────────────────
bool dailyLimitBreached  = i_dailyPnL  <= -dailyLossLimit
bool totalLimitBreached  = i_totalPnL  <= -maxLossLimit
bool profitReached       = i_totalPnL  >= profitTarget
bool dailyWarning        = i_showWarnings and (i_dailyPnL  <= -(dailyLossLimit * 0.75)) and not dailyLimitBreached
bool totalWarning        = i_showWarnings and (i_totalPnL  <= -(maxLossLimit   * 0.75)) and not totalLimitBreached
bool tradesLimitReached  = i_dailyTradesCount >= i_maxDailyTrades

float remainingDaily     = dailyLossLimit + i_dailyPnL
float remainingTotal     = maxLossLimit   + i_totalPnL
float remainingToTarget  = profitTarget   - i_totalPnL

float dailyPnLPct        = i_dailyPnL  / i_balance * 100
float totalPnLPct        = i_totalPnL  / i_balance * 100

// ─── ГОРИЗОНТАЛЬНІ ЛІНІЇ ─────────────────────────────────────
h1 = hline(i_showChart ? profitTarget     : na, "🎯 Profit Target",  color=#00C853, linestyle=hline.style_dashed, linewidth=1)
h2 = hline(i_showChart ? 0                : na, "Breakeven",         color=#546E7A, linestyle=hline.style_solid,  linewidth=1)
h3 = hline(i_showChart ? -dailyLossLimit  : na, "⚠️ Daily Limit",   color=#FFD600, linestyle=hline.style_dashed, linewidth=1)
h4 = hline(i_showChart ? -maxLossLimit    : na, "🛑 Max Loss",       color=#FF1744, linestyle=hline.style_dashed, linewidth=2)

// P&L лінії
plot(i_totalPnL, "Total P&L",
     color     = i_totalPnL >= 0 ? #00C853 : #FF1744,
     linewidth = 2,
     style     = plot.style_line)

plot(i_dailyPnL, "Daily P&L",
     color     = i_dailyPnL >= 0 ? color.new(#2196F3, 60) : color.new(#FF9800, 60),
     linewidth = 1,
     style     = plot.style_area)

// ─── DASHBOARD ТАБЛИЦЯ ───────────────────────────────────────
var table dash = table.new(
     position      = position.top_right,
     columns       = 2,
     rows          = 12,
     bgcolor       = #0D1117,
     border_color  = #30363D,
     border_width  = 1,
     frame_color   = #58A6FF,
     frame_width   = 1)

// helper — рядок таблиці
f_row(int row, string label, string val, color valColor) =>
    table.cell(dash, 0, row, label,
         text_color  = #8B949E,
         text_size   = size.small,
         bgcolor     = row % 2 == 0 ? #0D1117 : #161B22,
         text_halign = text.align_left)
    table.cell(dash, 1, row, val,
         text_color  = valColor,
         text_size   = size.small,
         bgcolor     = row % 2 == 0 ? #0D1117 : #161B22,
         text_halign = text.align_right)

// ── Заголовок
table.cell(dash, 0, 0, "⚡ FTMO RISK MANAGER",
     text_color  = #58A6FF,
     text_size   = size.normal,
     bgcolor     = #161B22,
     text_halign = text.align_center)
table.cell(dash, 1, 0, "Equity: $" + str.tostring(currentEquity, "#.##"),
     text_color  = currentEquity >= i_balance ? #00C853 : #FF1744,
     text_size   = size.normal,
     bgcolor     = #161B22,
     text_halign = text.align_center)

// ── Денний P&L
f_row(1, "📅 Денний P&L",
     (i_dailyPnL >= 0 ? "+" : "") + str.tostring(i_dailyPnL, "#.##") +
     "$ (" + (dailyPnLPct >= 0 ? "+" : "") + str.tostring(dailyPnLPct, "#.##") + "%)",
     dailyLimitBreached ? #FF1744 : dailyWarning ? #FFD600 : #00C853)

// ── Загальний P&L
f_row(2, "💰 Загальний P&L",
     (i_totalPnL >= 0 ? "+" : "") + str.tostring(i_totalPnL, "#.##") +
     "$ (" + (totalPnLPct >= 0 ? "+" : "") + str.tostring(totalPnLPct, "#.##") + "%)",
     totalLimitBreached ? #FF1744 : totalWarning ? #FFD600 : profitReached ? #00E676 : #00C853)

// ── Залишок до денного ліміту
f_row(3, "📏 До денного ліміту",
     "$" + str.tostring(math.max(remainingDaily, 0), "#.##"),
     remainingDaily <= dailyLossLimit * 0.25 ? #FF1744 : remainingDaily <= dailyLossLimit * 0.5 ? #FFD600 : #8B949E)

// ── Залишок до макс. збитку
f_row(4, "🛑 До макс. збитку",
     "$" + str.tostring(math.max(remainingTotal, 0), "#.##"),
     remainingTotal <= maxLossLimit * 0.25 ? #FF1744 : remainingTotal <= maxLossLimit * 0.5 ? #FFD600 : #8B949E)

// ── До цілі прибутку
f_row(5, "🎯 До цілі прибутку",
     profitReached ? "✅ ДОСЯГНУТО!" : "$" + str.tostring(math.max(remainingToTarget, 0), "#.##"),
     profitReached ? #00E676 : #2196F3)

// ── Ліміти
f_row(6, "⚠️ Daily Loss Limit",
     "-$" + str.tostring(dailyLossLimit, "#.##") + " (-" + str.tostring(i_dailyLossPct, "#.#") + "%)",
     #FFD600)

f_row(7, "🚫 Max Loss Limit",
     "-$" + str.tostring(maxLossLimit, "#.##") + " (-" + str.tostring(i_maxLossPct, "#.#") + "%)",
     #FF1744)

f_row(8, "🎲 Ризик/угода",
     "$" + str.tostring(riskPerTrade, "#.##") + " (" + str.tostring(i_riskPerTradePct, "#.#") + "%)",
     #2196F3)

// ── Лічильник угод
f_row(9, "🔢 Угод сьогодні",
     str.tostring(i_dailyTradesCount) + " / " + str.tostring(i_maxDailyTrades),
     tradesLimitReached ? #FF1744 : i_dailyTradesCount >= i_maxDailyTrades - 1 ? #FFD600 : #00C853)

// ── Початковий баланс
f_row(10, "🏦 Початковий баланс",
     "$" + str.tostring(i_balance, "#.##"),
     #8B949E)

// ── Статус
string statusText =
     totalLimitBreached  ? "🚫 СТОП — MAX LOSS BREACH!" :
     dailyLimitBreached  ? "🚫 СТОП — DAILY LOSS BREACH!" :
     tradesLimitReached  ? "🚫 СТОП — ЛІМІТ УГОД!" :
     profitReached       ? "✅ ЦІЛЬ ДОСЯГНУТА! СТОП." :
     totalWarning        ? "⚠️  ОБЕРЕЖНО — TOTAL -75%" :
     dailyWarning        ? "⚠️  ОБЕРЕЖНО — DAILY -75%" :
                           "✅ ВСЕ В НОРМІ"

color statusBg =
     totalLimitBreached or dailyLimitBreached or tradesLimitReached ? color.new(#FF1744, 70) :
     profitReached       ? color.new(#00C853, 70) :
     totalWarning or dailyWarning ? color.new(#FFD600, 80) :
     color.new(#00C853, 90)

table.cell(dash, 0, 11, "📍 СТАТУС",
     text_color  = #FFFFFF,
     text_size   = size.small,
     bgcolor     = statusBg,
     text_halign = text.align_center)
table.cell(dash, 1, 11, statusText,
     text_color  = #FFFFFF,
     text_size   = size.small,
     bgcolor     = statusBg,
     text_halign = text.align_center)

// ─── АЛЕРТИ ──────────────────────────────────────────────────
alertcondition(dailyWarning,
     "⚠️ Daily Loss 75%",
     "Увага! Денний збиток досяг 75% від ліміту. Будь обережний!")

alertcondition(dailyLimitBreached,
     "🚫 DAILY LOSS LIMIT",
     "СТОП! Денний ліміт збитку вичерпано. Більше не торгуй сьогодні!")

alertcondition(totalWarning,
     "⚠️ Total Loss 75%",
     "Увага! Загальний збиток досяг 75% від максимального ліміту!")

alertcondition(totalLimitBreached,
     "🚫 MAX LOSS BREACH",
     "СТОП! Максимальний збиток вичерпано. Рахунок умовно закрито!")

alertcondition(tradesLimitReached,
     "🚫 Ліміт угод вичерпано",
     "Сьогодні вже досягнуто максимальну кількість угод. СТОП торгівля!")

alertcondition(profitReached,
     "🎯 PROFIT TARGET!",
     "Вітаю! Ціль прибутку досягнута. Челендж умовно пройдено!")
