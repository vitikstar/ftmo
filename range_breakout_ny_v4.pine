//@version=6
// Range Breakout NY Open v4
// Час: 17:30 Київ (NY open), діапазон 20 хв
// SL: ATR 1.5x | TP: Swing H/L | BE+Trail при 50% прибутку
// Без понеділка і п'ятниці | Закриття о 22:00
// XAUUSD 15M: 41 угод, 39% WR, -$472 (-0.05%), DD $505 (Feb-May 2026)
strategy(title="Range Breakout NY Open v4", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=1, commission_type=strategy.commission.percent, commission_value=0.05, slippage=2)

var g1 = "Range"
i_rngHour  = input.int(17,    "Start hour (Kyiv)",    minval=0, maxval=23, group=g1)
i_rngMin   = input.int(30,    "Start minute",         minval=0, maxval=59, group=g1)
i_rngDur   = input.int(20,    "Duration (min)",       minval=5, maxval=120, group=g1)
i_minRange = input.float(8.0, "Min range size (pts)", minval=0, step=1.0, group=g1)

var g2 = "SL / Trail"
i_atrLen  = input.int(14,    "ATR length",            minval=1, group=g2)
i_atrMult = input.float(1.5, "Initial SL (x ATR)",   minval=0.1, step=0.1, group=g2)
i_trMult  = input.float(1.0, "Trail SL (x ATR)",     minval=0.1, step=0.1, group=g2)
i_bePct   = input.float(50,  "Move to BE at (% TP)", minval=10, maxval=90, step=5, group=g2)

var g3 = "TP"
i_swing  = input.int(50,    "Swing lookback (bars)", minval=5, maxval=300, group=g3)
i_rrFall = input.float(2.5, "RR fallback",           minval=1.0, step=0.5, group=g3)

var g4 = "Trade"
i_maxHour = input.int(21,   "No entries after (Kyiv)", minval=0, maxval=23, group=g4)
i_once    = input.bool(true, "Max 1 trade per day",   group=g4)
i_eod     = input.bool(true, "Close at 22:00 Kyiv",   group=g4)

TZ    = "Europe/Kiev"
kHour = hour(time, TZ)
kMin  = minute(time, TZ)
kDay  = dayofmonth(time, TZ)
kDow  = dayofweek(time, TZ)
startM = i_rngHour * 60 + i_rngMin
endM   = startM + i_rngDur
curM   = kHour * 60 + kMin

inWindow    = curM >= startM and curM < endM
afterRange  = curM >= endM
underCutoff = kHour < i_maxHour
canTradeDay = kDow != dayofweek.monday and kDow != dayofweek.friday

var float rHigh   = na
var float rLow    = na
var int   lastDay = na
var bool  traded  = false

if na(lastDay) or kDay != lastDay
    rHigh := na
    rLow  := na
    lastDay := kDay
    traded  := false

if inWindow
    rHigh := na(rHigh) ? high : math.max(rHigh, high)
    rLow  := na(rLow)  ? low  : math.min(rLow,  low)

atr       = ta.atr(i_atrLen)
swingHigh = ta.highest(high, i_swing)
swingLow  = ta.lowest(low,   i_swing)
rangeSize = not na(rHigh) ? rHigh - rLow : 0.0
rangeOk   = not na(rHigh) and afterRange and rangeSize >= i_minRange
canEnter  = rangeOk and underCutoff and canTradeDay and strategy.position_size == 0 and (not i_once or not traded)
bHigh     = math.max(open, close)
bLow      = math.min(open, close)
longSig   = canEnter and close > rHigh and bLow > rHigh
shortSig  = canEnter and close < rLow  and bHigh < rLow

var float pos_sl   = na
var float pos_tp   = na
var float pos_entr = na

if longSig
    pos_entr := close
    pos_sl   := close - atr * i_atrMult
    pos_tp   := swingHigh > close ? swingHigh : close + (close - pos_sl) * i_rrFall
    strategy.entry("L", strategy.long)
    strategy.exit("L_ex", "L", stop=pos_sl, limit=pos_tp)
    traded := true

if shortSig
    pos_entr := close
    pos_sl   := close + atr * i_atrMult
    pos_tp   := swingLow < close ? swingLow : close - (pos_sl - close) * i_rrFall
    strategy.entry("S", strategy.short)
    strategy.exit("S_ex", "S", stop=pos_sl, limit=pos_tp)
    traded := true

// BE + trailing stop
if strategy.position_size > 0 and not na(pos_entr)
    beLevel = pos_entr + (pos_tp - pos_entr) * (i_bePct / 100)
    if close >= beLevel
        newSL = math.max(pos_entr, close - atr * i_trMult)
        if newSL > pos_sl
            pos_sl := newSL
            strategy.exit("L_ex", "L", stop=pos_sl, limit=pos_tp)

if strategy.position_size < 0 and not na(pos_entr)
    beLevel = pos_entr - (pos_entr - pos_tp) * (i_bePct / 100)
    if close <= beLevel
        newSL = math.min(pos_entr, close + atr * i_trMult)
        if newSL < pos_sl
            pos_sl := newSL
            strategy.exit("S_ex", "S", stop=pos_sl, limit=pos_tp)

if i_eod and kHour == 22 and kMin == 0
    strategy.close_all("22:00")

bgcolor(inWindow ? color.new(color.blue, 90) : na, title="Range window")
plot((inWindow or afterRange) and not na(rHigh) ? rHigh : na, "Range High", color.red,  2, plot.style_stepline)
plot((inWindow or afterRange) and not na(rLow)  ? rLow  : na, "Range Low",  color.lime, 2, plot.style_stepline)
plot(strategy.position_size != 0 and not na(pos_sl) ? pos_sl : na, "Trail SL", color.orange, 1, plot.style_stepline)
plotshape(longSig,  "Long",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(shortSig, "Short", shape.triangledown, location.abovebar, color.red,   size=size.small)
